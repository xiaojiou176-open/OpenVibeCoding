    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "4.1.3",
    "jsdom": "29.0.2",

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/pm_intake_request.v1.json",
  "title": "PMIntakeRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "objective",
    "allowed_paths"
  ],
  "properties": {
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "cmd",
          "must_pass"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "cmd": {
            "type": "string"
          },
          "must_pass": {
            "type": "boolean"
          }
        }
      }
    },
    "tool_permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "filesystem",
        "shell",
        "network",
        "mcp_tools"
      ],
      "properties": {
        "filesystem": {
          "type": "string",
          "enum": [
            "read-only",
            "workspace-write"
          ]
        },
        "shell": {
          "type": "string",
          "enum": [
            "deny",
            "untrusted",
            "on-request",
            "never"
          ]
        },
        "network": {
          "type": "string",
          "enum": [
            "deny",
            "on-request",
            "allow"
          ]
        },
        "mcp_tools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "search_queries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task_template": {
      "type": "string",
      "minLength": 1
    },
    "template_payload": {
      "type": "object"
    },
    "answers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "owner_agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "agent_id"
      ],
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "PM",
            "TECH_LEAD",
            "WORKER",
            "REVIEWER",
            "TEST_RUNNER",
            "SEARCHER",
            "RESEARCHER",
            "UI_UX",
            "FRONTEND",
            "BACKEND",
            "AI",
            "SECURITY",
            "INFRA",
            "TEST",
            "OPS"
          ]
        },
        "agent_id": {
          "type": "string"
        }
      }
    },
    "mcp_tool_set": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "该任务所需的 MCP 工具集"
    },
    "audit_only": {
      "type": "boolean",
      "default": false,
      "description": "仅审计任务（允许空 diff 的 reviewer 例外）"
    },
    "browser_policy_preset": {
      "type": "string",
      "enum": [
        "safe",
        "balanced",
        "aggressive",
        "custom"
      ]
    },
    "requester_role": {
      "type": "string",
      "enum": [
        "PM",
        "TECH_LEAD",
        "WORKER",
        "REVIEWER",
        "TEST_RUNNER",
        "SEARCHER",
        "RESEARCHER",
        "UI_UX",
        "FRONTEND",
        "BACKEND",
        "AI",
        "SECURITY",
        "INFRA",
        "TEST",
        "OPS",
        "OWNER",
        "ARCHITECT"
      ]
    },
    "browser_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile_mode": {
          "type": "string",
          "enum": [
            "ephemeral",
            "allow_profile",
            "cookie_file"
          ]
        },
        "profile_ref": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "profile_dir": {
              "type": "string",
              "minLength": 1
            },
            "profile_name": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "cookie_ref": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cookie_path": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "stealth_mode": {
          "type": "string",
          "enum": [
            "none",
            "lite",
            "plugin"
          ]
        },
        "human_behavior": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "level": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ]
            }
          }
        }
      }
    }
  }
}

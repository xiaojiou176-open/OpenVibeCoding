{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/unblock_task.v1.json",
  "title": "UnblockTask",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "unblock_task_id",
    "source_prompt_contract_id",
    "objective",
    "scope_hint",
    "assigned_agent",
    "owner",
    "mode",
    "status",
    "trigger",
    "reason",
    "verification_requirements"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v1"
    },
    "unblock_task_id": {
      "type": "string",
      "minLength": 1
    },
    "source_prompt_contract_id": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "scope_hint": {
      "type": "string",
      "minLength": 1
    },
    "assigned_agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "agent_id"
      ],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1
        },
        "agent_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "owner": {
      "type": "string",
      "enum": [
        "L0"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "independent_temporary_task"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "queued",
        "opened",
        "resolved"
      ]
    },
    "trigger": {
      "type": "string",
      "enum": [
        "spawn_independent_temporary_unblock_task"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "verification_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}

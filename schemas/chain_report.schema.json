{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/chain_report.schema.json",
  "title": "ChainReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "chain_id",
    "run_id",
    "status",
    "steps",
    "timestamps"
  ],
  "properties": {
    "chain_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "FAILURE",
        "PARTIAL"
      ]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "index",
          "name",
          "kind",
          "task_id",
          "run_id",
          "status"
        ],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "name": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "plan",
              "contract",
              "handoff"
            ]
          },
          "task_id": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "failure_reason": {
            "type": "string"
          },
          "owner_agent": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "role": {
                "type": "string",
                "enum": [
                  "PM",
                  "TECH_LEAD",
                  "WORKER",
                  "REVIEWER",
                  "TEST_RUNNER",
                  "SEARCHER",
                  "RESEARCHER",
                  "UI_UX",
                  "FRONTEND",
                  "BACKEND",
                  "AI",
                  "SECURITY",
                  "INFRA",
                  "TEST",
                  "OPS"
                ]
              },
              "agent_id": {
                "type": "string"
              },
              "codex_thread_id": {
                "type": "string"
              }
            }
          },
          "assigned_agent": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "role": {
                "type": "string",
                "enum": [
                  "PM",
                  "TECH_LEAD",
                  "WORKER",
                  "REVIEWER",
                  "TEST_RUNNER",
                  "SEARCHER",
                  "RESEARCHER",
                  "UI_UX",
                  "FRONTEND",
                  "BACKEND",
                  "AI",
                  "SECURITY",
                  "INFRA",
                  "TEST",
                  "OPS"
                ]
              },
              "agent_id": {
                "type": "string"
              },
              "codex_thread_id": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enforce",
        "required_path",
        "observed_path",
        "missing_required_roles",
        "is_complete",
        "workers",
        "reviewers",
        "tests",
        "return_to_pm"
      ],
      "properties": {
        "enforce": {
          "type": "boolean"
        },
        "required_path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "observed_path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_required_roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "is_complete": {
          "type": "boolean"
        },
        "workers": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "observed",
            "ok"
          ],
          "properties": {
            "required": {
              "type": "integer",
              "minimum": 1
            },
            "observed": {
              "type": "integer",
              "minimum": 0
            },
            "ok": {
              "type": "boolean"
            }
          }
        },
        "reviewers": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "observed",
            "quorum",
            "pass",
            "fail",
            "blocked",
            "unknown",
            "quorum_met",
            "ok"
          ],
          "properties": {
            "required": {
              "type": "integer",
              "minimum": 1
            },
            "observed": {
              "type": "integer",
              "minimum": 0
            },
            "quorum": {
              "type": "integer",
              "minimum": 1
            },
            "pass": {
              "type": "integer",
              "minimum": 0
            },
            "fail": {
              "type": "integer",
              "minimum": 0
            },
            "blocked": {
              "type": "integer",
              "minimum": 0
            },
            "unknown": {
              "type": "integer",
              "minimum": 0
            },
            "quorum_met": {
              "type": "boolean"
            },
            "ok": {
              "type": "boolean"
            }
          }
        },
        "tests": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "require_test_stage",
            "observed",
            "pass",
            "ok"
          ],
          "properties": {
            "require_test_stage": {
              "type": "boolean"
            },
            "observed": {
              "type": "integer",
              "minimum": 0
            },
            "pass": {
              "type": "integer",
              "minimum": 0
            },
            "ok": {
              "type": "boolean"
            }
          }
        },
        "return_to_pm": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "ok"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "ok": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "timeouts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "count",
        "timed_out_steps",
        "timeout_sec",
        "timeout_sec_values",
        "timed_out_commands"
      ],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "timed_out_steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeout_sec": {
          "anyOf": [
            {
              "type": "number",
              "exclusiveMinimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "timeout_sec_values": {
          "type": "array",
          "items": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        },
        "timed_out_commands": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "finished_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}

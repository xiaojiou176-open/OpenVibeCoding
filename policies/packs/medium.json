{
  "version": "v1",
  "allow": [
    {"exec": "codex", "argv_prefixes": [["codex", "exec"], ["codex", "exec", "resume"]]},
    {"exec": "git", "argv_prefixes": [["git"]]},
    {"exec": "echo", "argv_prefixes": [["echo"]]},
    {"exec": "pytest", "argv_prefixes": [["pytest"]]},
    {"exec": "python", "argv_prefixes": [["python", "-m", "pytest"], ["python", "-m", "openvibecoding_orch.cli"]]},
    {"exec": "python3", "argv_prefixes": [["python3", "-m", "pytest"], ["python3", "-m", "openvibecoding_orch.cli"]]},
    {"exec": "npm", "argv_prefixes": [["npm", "test"]]},
    {"exec": "node", "argv_prefixes": [["node"]]},
    {"exec": "bash", "argv_prefixes": [["bash"]]},
    {"exec": "sh", "argv_prefixes": [["sh"]]}
  ],
  "deny_substrings": [
    "rm -rf",
    "sudo",
    "ssh ",
    "scp ",
    "sftp ",
    "curl ",
    "wget ",
    ".env",
    ".runtime-cache/openvibecoding/",
    "git push",
    "git reset --hard",
    "git clean -fd"
  ],
  "forbidden_actions": ["git push", "git reset --hard", "git clean -fd"]
}

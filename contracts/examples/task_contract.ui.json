{
  "task_id": "task_ui_example",
  "owner_agent": {
    "role": "WORKER",
    "agent_id": "cortexpilot-worker-1",
    "codex_thread_id": ""
  },
  "assigned_agent": {
    "role": "WORKER",
    "agent_id": "cortexpilot-worker-1",
    "codex_thread_id": ""
  },
  "inputs": {
    "spec": "示例 UI 任务：更新 dashboard 页面",
    "artifacts": []
  },
  "required_outputs": [
    {
      "name": "apps/dashboard/app/page.tsx",
      "type": "file",
      "acceptance": "页面能正常渲染且无 TypeScript 错误"
    }
  ],
  "allowed_paths": [
    "apps/dashboard"
  ],
  "forbidden_actions": [
    "rm -rf",
    "git push"
  ],
  "acceptance_tests": [
    {
      "name": "dashboard tests",
      "cmd": "npm test --prefix apps/dashboard",
      "must_pass": true
    }
  ],
  "tool_permissions": {
    "filesystem": "workspace-write",
    "shell": "on-request",
    "network": "deny",
    "mcp_tools": [
      "codex"
    ]
  },
  "timeout_retry": {
    "timeout_sec": 900,
    "max_retries": 1,
    "retry_backoff_sec": 3
  },
  "rollback": {
    "strategy": "git_reset_hard",
    "baseline_ref": "HEAD"
  },
  "evidence_links": [],
  "log_refs": {
    "run_id": "",
    "paths": {
      "codex_jsonl": "",
      "codex_transcript": "",
      "git_diff": "",
      "tests_log": "",
      "trace_id": ""
    }
  },
  "mcp_tool_set": [
    "01-filesystem"
  ]
}
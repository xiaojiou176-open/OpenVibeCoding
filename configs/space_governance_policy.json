{
  "version": 1,
  "recent_activity_hours": 24,
  "apply_gate_max_age_minutes": 15,
  "machine_cache_retention_policy": {
    "default_cap_bytes": 21474836480,
    "auto_prune_interval_sec": 1800,
    "protected_prefixes": [
      "${OPENVIBECODING_MACHINE_CACHE_ROOT}/browser",
      "${OPENVIBECODING_MACHINE_CACHE_ROOT}/toolchains",
      "${OPENVIBECODING_MACHINE_CACHE_ROOT}/toolchains/python/current"
    ],
    "cap_excluded_prefixes": [
      "${OPENVIBECODING_MACHINE_CACHE_ROOT}/browser"
    ]
  },
  "shared_realpath_prefixes": [
    "~/.cache/jarvis"
  ],
  "process_groups": {
    "node": {
      "patterns": [
        "\\bnode\\b",
        "\\bpnpm\\b",
        "\\bnext\\b",
        "\\bvite\\b",
        "\\bvitest\\b"
      ]
    },
    "python": {
      "patterns": [
        "\\bpython(3(\\.\\d+)?)?\\b",
        "\\buv\\b",
        "\\bpytest\\b"
      ]
    },
    "playwright": {
      "patterns": [
        "playwright",
        "chromium",
        "webkit",
        "firefox"
      ]
    },
    "cargo": {
      "patterns": [
        "\\bcargo\\b",
        "\\brustc\\b",
        "\\brustup\\b"
      ]
    },
    "tauri": {
      "patterns": [
        "\\btauri\\b"
      ]
    },
    "docker": {
      "patterns": [
        "\\bdocker\\b",
        "containerd",
        "buildkit"
      ]
    }
  },
  "rebuild_commands": [
    {
      "id": "bootstrap",
      "kind": "npm_script",
      "script": "bootstrap",
      "description": "repo bootstrap"
    },
    {
      "id": "test_quick",
      "kind": "npm_script",
      "script": "test:quick",
      "description": "repo quick verification"
    },
    {
      "id": "dashboard_build",
      "kind": "npm_script",
      "script": "dashboard:build",
      "description": "dashboard build"
    },
    {
      "id": "desktop_build",
      "kind": "npm_script",
      "script": "desktop:build",
      "description": "desktop build"
    },
    {
      "id": "desktop_tauri_build",
      "kind": "npm_script",
      "script": "desktop:tauri:build",
      "description": "desktop tauri build"
    },
    {
      "id": "dashboard_deps",
      "kind": "shell_script",
      "path": "scripts/install_dashboard_deps.sh",
      "description": "dashboard dependency reinstall"
    },
    {
      "id": "desktop_deps",
      "kind": "shell_script",
      "path": "scripts/install_desktop_deps.sh",
      "description": "desktop dependency reinstall"
    },
    {
      "id": "frontend_api_client_deps",
      "kind": "shell_script",
      "path": "scripts/install_frontend_api_client_deps.sh",
      "description": "frontend API client dependency reinstall"
    },
    {
      "id": "orchestrator_python",
      "kind": "shell_script",
      "path": "scripts/bootstrap.sh",
      "args": [
        "python"
      ],
      "description": "orchestrator python environment bootstrap"
    },
    {
      "id": "bootstrap_playwright",
      "kind": "shell_script",
      "path": "scripts/bootstrap.sh",
      "args": [
        "playwright"
      ],
      "description": "Playwright browser bootstrap"
    },
    {
      "id": "docker_ci_test_quick",
      "kind": "shell_script",
      "path": "scripts/docker_ci.sh",
      "args": [
        "test-quick"
      ],
      "description": "local docker_ci quick verification"
    },
    {
      "id": "clean_room_recovery",
      "kind": "shell_script",
      "path": "scripts/check_clean_room_recovery.sh",
      "args": [
        "--skip-governance-scorecard"
      ],
      "description": "clean-room recovery verification"
    },
    {
      "id": "desktop_native_smoke",
      "kind": "shell_script",
      "path": "scripts/docker_ci.sh",
      "args": [
        "lane",
        "desktop-native-smoke"
      ],
      "description": "desktop native smoke verification"
    }
  ],

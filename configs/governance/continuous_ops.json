          "target_partial_max": 56,
          "target_covered_min": 7,
          "min_weekly_gap_reduction": 1.0
        },
        {
          "week_offset": 4,
          "target_partial_max": 50,
          "target_covered_min": 13,
          "min_weekly_gap_reduction": 1.5
        },
        {
          "week_offset": 6,

  "p2_critical_flake_gate": {
    "enabled": true,
    "commands_file_default": "scripts/ui_regression_p2_critical.commands",
    "commands_file_quick": "scripts/ui_regression_p2_critical.quick.commands",
    "iterations_default": 4,
    "iterations_quick": 1,
    "threshold_percent_default": 1.5,
    "threshold_percent_quick": 5.0,
    "max_workers_default": 1,
    "max_workers_quick": 1
  },
  "trend_gate": {
    "enabled": false,
    "command": "python3 scripts/ui_regression_trend_append.py --p0-report \"$P0_REPORT\" --p1-report \"$P1_REPORT\" --truth-report \"$TRUTH_REPORT\""
  },
  "recent_streak": {
    "enabled": true,
    "windows": [
      7,
      14
    ],
    "strict": false,
    "workflow_file": ".github/workflows/continuous-governance.yml"
